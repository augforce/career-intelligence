# Copy this file to ".env" and fill in your free API keys to unlock the broader
# job sources. The three free boards (RemoteOK, Remotive, Arbeitnow) need NOTHING here.
#
# JSearch (Google for Jobs -> LinkedIn/Indeed/Glassdoor/ZipRecruiter).
#   Get a free key (200 searches/month) at https://rapidapi.com (search "JSearch")
#   or https://www.openwebninja.com/api/jsearch
JSEARCH_API_KEY=

# Adzuna (broad US listings + salary). Free registration at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: local server port (default 8900). Change if it conflicts with another tool.
# CI_PORT=8901

# Optional Claude analysis layer: reads each surviving job and judges real remote status
# + skill-fit. Get a key + add credits at https://console.anthropic.com (separate from
# your Claude Max plan). Leave blank to stay fully deterministic / free.
ANTHROPIC_API_KEY=
# Model used for judging (default claude-haiku-4-5 — cheapest). For sharper judgment:
# CI_CLAUDE_MODEL=claude-opus-4-8
